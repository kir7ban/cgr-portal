# ============================================================================
# Bosch Internal Communications Platform - Environment Configuration
# ============================================================================
#
# Copy this file to .env and populate with actual values for your environment.
# For Azure deployment, these are set via az webapp config appsettings.
#
# DO NOT commit .env to version control (add to .gitignore)
#

# ============================================================================
# Application Environment
# ============================================================================

NODE_ENV=development
ENVIRONMENT=dev
PORT=3000

# ============================================================================
# Azure CosmosDB Configuration
# ============================================================================

# Full connection string for CosmosDB
# Format: AccountEndpoint=https://<account>.documents.azure.com:443/;AccountKey=<key>;
COSMOSDB_CONNECTION_STRING=

# CosmosDB account endpoint (e.g., https://cgr-dev-db.documents.azure.com:443/)
COSMOSDB_ENDPOINT=

# CosmosDB primary access key
COSMOSDB_PRIMARY_KEY=

# CosmosDB database name
COSMOSDB_DATABASE=cgr_platform

# ============================================================================
# Authentication & Security
# ============================================================================

# JWT Secret for token signing (should be a long random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-here

# JWT token expiration (e.g., 7d, 24h, 3600 seconds)
JWT_EXPIRATION=7d

# ============================================================================
# Monitoring & Logging
# ============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable request logging
LOG_REQUESTS=true

# ============================================================================
# Feature Flags (MVP)
# ============================================================================

# Enable mock authentication (dev/staging only)
MOCK_AUTH_ENABLED=true

# Enable detailed health check diagnostics
HEALTH_CHECK_DETAILED=false

# ============================================================================
# Application Configuration
# ============================================================================

# Maximum file upload size (bytes, default 10MB)
MAX_UPLOAD_SIZE=10485760

# Maximum number of images per post
MAX_IMAGES_PER_POST=3

# Maximum image file size (bytes, default 5MB)
MAX_IMAGE_SIZE=5242880

# Auto-archive posts after days
AUTO_ARCHIVE_DAYS=365

# Audit log retention days
AUDIT_LOG_RETENTION_DAYS=1095

# ============================================================================
# Azure App Service Configuration (Production)
# ============================================================================

# Azure resource group name
AZURE_RESOURCE_GROUP=cgr-prod-rg

# Azure App Service name
AZURE_APP_SERVICE=cgr-prod-api

# Azure CosmosDB account name
AZURE_COSMOSDB_ACCOUNT=cgrproddb

# ============================================================================
# Development-Only Configuration
# ============================================================================

# Watch mode for local development
WATCH_MODE=true

# Debug output
DEBUG=cgr:*

# TypeScript source maps
TS_NODE_SOURCE_MAP=true
